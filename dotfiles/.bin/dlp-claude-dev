#!/bin/sh
# Points claude code at DLPNet LLM Router

export ANTHROPIC_BASE_URL=http://127.0.0.1:8080/v1/llm/default_agentic
export CLAUDE_CODE_OAUTH_TOKEN="$(cat ~/.claude/dlp-api-debug-auth-key)"
# Improve prompt-cache hit rates, disable telemetry, and strip cloud creds from subprocess envs
export CLAUDE_CODE_ATTRIBUTION_HEADER="0"
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC="1"
export CLAUDE_CODE_SUBPROCESS_ENV_SCRUB="1"

exec claude "$@"
